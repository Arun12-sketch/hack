# Agent wallet private key (executes on-chain actions on behalf of users)
AGENT_PRIVATE_KEY=0x_your_agent_private_key_here

# Planner mode: "cli" (Claude CLI proxy) or "api" (Anthropic SDK)
PLANNER_MODE=cli

# Codex CLI proxy URL (cli mode only, host.docker.internal for Docker)
CLAUDE_PROXY_URL=http://host.docker.internal:3003

# Codex model and reasoning effort (cli mode only, passed to proxy)
CODEX_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=xhigh

# Anthropic API key (api mode only)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Creditcoin Testnet RPC
RPC_URL=https://rpc.cc3-testnet.creditcoin.network
